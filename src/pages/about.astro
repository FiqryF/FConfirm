---
import "../../styles.css";
---

<!doctype html>
<html lang="id">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>About | Fiqry Firmansyah</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&family=Outfit:wght@500;700;900&display=swap"
      rel="stylesheet"
    />
  </head>
  <body data-home-only>
    <header class="site-header">
      <a class="brand" href="/">FIQRY FIRMANSYAH</a>
      <nav class="nav-links" aria-label="Navigasi utama">
        <a href="/">Home</a>
        <a href="/about">About</a>
      </nav>
      <button class="theme-toggle" type="button" aria-label="Switch theme" data-theme-toggle>
        <span class="theme-toggle-track" aria-hidden="true">
          <span class="theme-toggle-dot"></span>
        </span>
        <span data-theme-label>Night</span>
      </button>
    </header>

    <main class="about-page">
      <section class="about-hero">
        <p class="section-eyebrow">About Me</p>
        <h1>Frontend developer who cares about clarity, performance, and visual polish.</h1>
        <p>
          Saya membangun interface web yang bersih, responsif, dan mudah digunakan. Fokus saya ada
          pada struktur halaman, detail visual, serta pengalaman pengguna yang konsisten dari mobile
          sampai desktop.
        </p>
      </section>

      <section class="about-detail-grid">
        <article class="about-detail-card">
          <p class="section-eyebrow">Profile</p>
          <h2>Tentang Saya</h2>
          <p>
            Saya tertarik pada frontend development karena menggabungkan logika, estetika, dan
            pengalaman pengguna. Dalam setiap project, saya berusaha membuat tampilan yang tidak
            hanya bagus dilihat, tetapi juga rapi secara struktur dan nyaman digunakan.
          </p>
        </article>

        <article class="about-detail-card">
          <p class="section-eyebrow">Experience</p>
          <h2>Pengalaman</h2>
          <ul class="timeline-list">
            <li>
              <strong>Portfolio & Landing Page</strong>
              <span>Membangun halaman personal branding, landing page, dan UI presentasi project.</span>
            </li>
            <li>
              <strong>Responsive Interface</strong>
              <span>Menyesuaikan layout untuk desktop, tablet, dan mobile dengan detail spacing.</span>
            </li>
            <li>
              <strong>Design Implementation</strong>
              <span>Menerjemahkan referensi visual/Figma menjadi halaman web yang hidup.</span>
            </li>
          </ul>
        </article>

        <article class="about-detail-card about-skill-card">
          <p class="section-eyebrow">Skills</p>
          <h2>Skill Utama</h2>
          <div class="skill-cloud">
            <span>Astro</span>
            <span>HTML</span>
            <span>CSS</span>
            <span>JavaScript</span>
            <span>Responsive Design</span>
            <span>UI Layout</span>
            <span>Figma</span>
            <span>Frontend Polish</span>
          </div>
        </article>
      </section>
    </main>

    <script is:inline>
      const root = document.documentElement;
      const themeToggle = document.querySelector("[data-theme-toggle]");
      const themeLabel = document.querySelector("[data-theme-label]");

      function setTheme(theme) {
        root.dataset.theme = theme;
        localStorage.setItem("theme", theme);
        if (themeLabel) themeLabel.textContent = theme === "night" ? "Night" : "Light";
      }

      setTheme(localStorage.getItem("theme") || "night");

      themeToggle?.addEventListener("click", () => {
        setTheme(root.dataset.theme === "night" ? "light" : "night");
      });
    </script>
  </body>
</html>
