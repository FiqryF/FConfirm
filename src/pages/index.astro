---
import "../../styles.css";
import { photoProjects, webProjects } from "../data/projectShowcase.js";
---

<!doctype html>
<html lang="id">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Fiqry Firmansyah | Portfolio</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&family=Outfit:wght@500;700;900&display=swap"
      rel="stylesheet"
    />
  </head>
  <body data-home-only>
    <header class="site-header">
      <a class="brand" href="#home">FIQRY FIRMANSYAH</a>
      <nav class="nav-links" aria-label="Navigasi utama">
        <a class="active" href="#home">Home</a>
        <a href="#about">About</a>
        <a href="#projects">Project</a>
        <a href="#contact">Contact</a>
      </nav>
    </header>

    <main>
      <section class="hero" id="home">
        <div class="hero-copy">
          <p class="hero-badge"><span></span> Available for freelance projects</p>
          <h1>
            HI, I AM<br />
            FIQRY<span class="mobile-name-break"></span> FIRMANSYAH.
          </h1>
          <p class="intro">
            A Sydney based front-end developer passionate about building accessible and user friendly
            websites.
          </p>
          <div class="hero-actions">
            <a class="primary-button" href="mailto:fiqry@example.com">Contact Me</a>
            <a class="icon-button" href="https://www.linkedin.com/" aria-label="LinkedIn">
              <img src="https://cdn.jsdelivr.net/gh/devicons/devicon/icons/linkedin/linkedin-original.svg" alt="" />
            </a>
            <a class="icon-button" href="https://github.com/" aria-label="GitHub">
              <img src="https://cdn.jsdelivr.net/gh/devicons/devicon/icons/github/github-original.svg" alt="" />
            </a>
          </div>
          <div class="hero-stack" aria-label="Core frontend tools">
            <span>Astro</span>
            <span>JavaScript</span>
            <span>CSS</span>
            <span>Figma</span>
          </div>
        </div>
        <div class="hero-visual">
          <div class="portrait-card">
            <img
              src="https://images.unsplash.com/photo-1507003211169-0a1dd7228f2d?auto=format&fit=crop&w=900&q=90"
              alt="Foto portrait profesional"
            />
          </div>
          <div class="hero-note">
            <strong>Frontend</strong>
            <span>Clean UI / Fast pages / Responsive layouts</span>
          </div>
          <div class="hero-year">2026</div>
        </div>
      </section>

      <section class="about-preview" id="about">
        <div class="about-preview-copy">
          <p class="section-eyebrow">About Me</p>
          <h2>I build clean digital interfaces with strong structure and responsive detail.</h2>
          <p>
            Saya fokus membuat website yang terlihat modern, ringan, dan nyaman digunakan di semua
            device. Pendekatan saya menggabungkan visual design, semantic HTML, CSS yang rapi, dan
            JavaScript seperlunya agar halaman tetap cepat.
          </p>
          <a class="secondary-button" href="/about">Selengkapnya</a>
        </div>
        <div class="about-preview-panel" aria-label="Profile highlights">
          <div class="about-system-card">
            <span class="system-label">Working System</span>
            <strong>Design-aware frontend workflow</strong>
            <p>From layout structure to responsive polish, every section is built to feel intentional.</p>
          </div>
          <div class="about-meter-card">
            <div>
              <span>Frontend Build</span>
              <strong>92%</strong>
            </div>
            <i style="--value: 92%"></i>
          </div>
          <div class="about-meter-card">
            <div>
              <span>Responsive Detail</span>
              <strong>88%</strong>
            </div>
            <i style="--value: 88%"></i>
          </div>
          <div class="about-meter-card">
            <div>
              <span>Visual Polish</span>
              <strong>90%</strong>
            </div>
            <i style="--value: 90%"></i>
          </div>
          <div class="about-mini-grid">
            <span><strong>03</strong> Core focus</span>
            <span><strong>08</strong> Tools</span>
            <span><strong>100%</strong> Mobile-first</span>
          </div>
          <div class="about-tech-stack" aria-label="Tech stack yang dikuasai">
            <span title="Astro">
              <img src="https://cdn.jsdelivr.net/gh/devicons/devicon/icons/astro/astro-original.svg" alt="" />
            </span>
            <span title="JavaScript">
              <img src="https://cdn.jsdelivr.net/gh/devicons/devicon/icons/javascript/javascript-original.svg" alt="" />
            </span>
            <span title="HTML5">
              <img src="https://cdn.jsdelivr.net/gh/devicons/devicon/icons/html5/html5-original.svg" alt="" />
            </span>
            <span title="CSS3">
              <img src="https://cdn.jsdelivr.net/gh/devicons/devicon/icons/css3/css3-original.svg" alt="" />
            </span>
            <span title="Figma">
              <img src="https://cdn.jsdelivr.net/gh/devicons/devicon/icons/figma/figma-original.svg" alt="" />
            </span>
            <span title="Tailwind CSS">
              <img src="https://cdn.jsdelivr.net/gh/devicons/devicon/icons/tailwindcss/tailwindcss-original.svg" alt="" />
            </span>
          </div>
        </div>
      </section>

      <section class="project-showcase" id="projects">
        <div class="project-heading">
          <p class="section-eyebrow">Selected Project</p>
          <h2>Recent work across web interfaces and photography.</h2>
          <div class="project-tabs" role="tablist" aria-label="Project category">
            <button class="project-tab is-active" type="button" data-project-tab="web">Web</button>
            <button class="project-tab" type="button" data-project-tab="photo">Photography</button>
          </div>
        </div>

        <div class="project-panels">
          <div class="project-panel is-active" data-project-panel="web" id="project-web">
            <div class="project-panel-top">
              <span>Web Project</span>
              <a class="project-see-more" href="/projects">Selengkapnya</a>
            </div>
            <div class="modern-project-grid">
              {
                webProjects.map((project) => (
                  <article class="modern-project-card">
                    <a href="#projects" aria-label={`Lihat project ${project.title}`}>
                      <div class="modern-project-media">
                        <img src={project.image} alt={project.title} loading="lazy" />
                        <span>{project.year}</span>
                      </div>
                      <div class="modern-project-body">
                        <p>{project.type}</p>
                        <h3>{project.title}</h3>
                        <span>{project.description}</span>
                        <div class="project-tech-row" aria-label={`Tech stack ${project.title}`}>
                          {
                            project.tech.map((tech) => (
                              <span title={tech.label}>
                                <img src={tech.icon} alt="" loading="lazy" />
                              </span>
                            ))
                          }
                        </div>
                      </div>
                    </a>
                  </article>
                ))
              }
            </div>
          </div>

          <div class="project-panel" data-project-panel="photo" id="project-photography">
            <div class="project-panel-top">
              <span>Photography Project</span>
              <a class="project-see-more" href="/projects/photography">Selengkapnya</a>
            </div>
            <div class="modern-project-grid photo-project-grid">
              {
                photoProjects.map((project) => (
                  <article class:list={["modern-project-card", "photo-project-card", `photo-${project.layout || "normal"}`]}>
                    <a href="#projects" aria-label={`Lihat project ${project.title}`}>
                      <div class="modern-project-media">
                        <img src={project.image} alt={project.title} loading="lazy" />
                        <div class="photo-project-overlay">
                          <p>{project.type}</p>
                          <h3>{project.title}</h3>
                          <span>{project.description}</span>
                        </div>
                      </div>
                    </a>
                  </article>
                ))
              }
            </div>
          </div>
        </div>
      </section>

      <section class="contact-simple" id="contact">
        <div>
          <p class="section-eyebrow">Contact Me</p>
          <h2>Let's stay connected.</h2>
          <p>
            Terima kasih sudah melihat portfolio saya. Jika ingin terhubung, berdiskusi, atau
            melihat update karya terbaru saya, silakan hubungi melalui link di bawah.
          </p>
        </div>
        <div class="contact-actions">
          <a class="primary-button" href="mailto:fiqry@example.com">Email Me</a>
          <a class="contact-link contact-icon-link" href="https://www.linkedin.com/" aria-label="LinkedIn">
            <img src="https://cdn.jsdelivr.net/gh/devicons/devicon/icons/linkedin/linkedin-original.svg" alt="" />
          </a>
          <a class="contact-link contact-icon-link" href="https://github.com/" aria-label="GitHub">
            <img src="https://cdn.jsdelivr.net/gh/devicons/devicon/icons/github/github-original.svg" alt="" />
          </a>
        </div>
      </section>
    </main>

    <footer class="site-footer-simple">
      <a class="brand" href="#home">FIQRY FIRMANSYAH</a>
      <p>Frontend developer and photography enthusiast.</p>
      <nav aria-label="Footer navigation">
        <a href="#home">Home</a>
        <a href="#about">About</a>
        <a href="#projects">Project</a>
        <a href="#contact">Contact</a>
      </nav>
    </footer>

    <script is:inline>
      const root = document.documentElement;
      const themeToggle = document.querySelector("[data-theme-toggle]");
      const themeLabel = document.querySelector("[data-theme-label]");

      function setTheme(theme) {
        root.dataset.theme = theme;
        localStorage.setItem("theme", theme);
        if (themeLabel) themeLabel.textContent = theme === "night" ? "Night" : "Light";
      }

      setTheme(localStorage.getItem("theme") || "night");

      themeToggle?.addEventListener("click", () => {
        setTheme(root.dataset.theme === "night" ? "light" : "night");
      });

      const projectTabs = document.querySelectorAll("[data-project-tab]");
      const projectPanels = document.querySelectorAll("[data-project-panel]");

      projectTabs.forEach((tab) => {
        tab.addEventListener("click", () => {
          const target = tab.dataset.projectTab;

          projectTabs.forEach((item) => item.classList.toggle("is-active", item === tab));
          projectPanels.forEach((panel) => {
            panel.classList.toggle("is-active", panel.dataset.projectPanel === target);
          });
        });
      });
    </script>
  </body>
</html>
